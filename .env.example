# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres
SUPABASE_STORAGE_BUCKET=yt-newsletter-assets

# YouTube
YOUTUBE_API_KEY=your-youtube-data-api-key

# AI providers
DEEPSEEK_API_KEY=your-deepseek-api-key
KIMI_API_KEY=your-kimi-api-key
QWEN_API_KEY=your-qwen-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
GEMINI_API_KEY=your-gemini-api-key

# First local admin
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=replace-with-a-long-password
ALLOW_PUBLIC_SIGNUP=false

# App secrets generated locally by `npm run env:setup`
CRON_SECRET=replace-with-random-secret
COOKIE_SECRET=replace-with-random-secret
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Model routing defaults
DEEPSEEK_DAILY_MODEL=deepseek-chat
QWEN_DAILY_FALLBACK_MODEL=qwen-plus
KIMI_WEEKLY_MODEL=moonshot-v1-32k
DEEPSEEK_WEEKLY_FALLBACK_MODEL=deepseek-chat
GEMINI_VIDEO_MODEL=gemini-2.5-flash
QWEN_IMAGE_MODEL=wanx2.1-t2i-plus
QWEN_TTS_MODEL=cosyvoice-v1

# Workload and cost guardrails
TRANSCRIPT_RETRY_HOURS=24
MONTHLY_AI_BUDGET_USD=25
MAX_BACKFILL_VIDEOS_PER_JOB=50
BASELINE_MONTH_VIDEO_LOOKBACK_LIMIT=50
MAX_VIDEOS_PROCESSED_PER_CRON_RUN=3
GENERATE_IMAGES=false
GENERATE_AUDIO=false
